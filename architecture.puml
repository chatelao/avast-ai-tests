@startuml
actor User
participant GHA as "GitHub Actions\n(vast_ai_benchmark.yml)"
participant Launch as "Launch Script\n(launch.py)"
participant Poll as "Poll Script\n(poll.py)"
participant Bench as "Benchmark Script\n(benchmark.py)"
participant Teardown as "Teardown Script\n(teardown.py)"
participant VastAPI as "Vast.ai API"
participant GPUInstance as "vLLM Engine\n(GPU Instance)"

User -> GHA ++ : Trigger Workflow
GHA -> Launch ++ : Execute
Launch -> VastAPI ++ : Search & Rent Instance
VastAPI --> Launch -- : Instance ID
Launch -> Launch : Save ID to .vast_instance_id
Launch --> GHA -- : Success

GHA -> Poll ++ : Execute
Poll -> Poll : Read ID from .vast_instance_id
Poll -> VastAPI ++ : Get Instance Details
VastAPI --> Poll -- : IP & Port Mappings
Poll -> GPUInstance ++ : Health Check (/v1/models)
GPUInstance --> Poll -- : 200 OK
Poll -> Poll : Save URL to .vast_api_url
Poll --> GHA -- : API Ready

GHA -> Bench ++ : Execute
Bench -> Bench : Read URL from .vast_api_url
loop for each concurrency level
    Bench -> GPUInstance ++ : Load Test Request
    GPUInstance --> Bench -- : Token Stream
end
Bench -> GHA : Upload Results (Step Summary)
deactivate Bench

GHA -> Teardown ++ : Execute (Always)
Teardown -> Teardown : Read ID from .vast_instance_id
Teardown -> VastAPI ++ : Destroy Instance
VastAPI --> Teardown -- : Success
Teardown -> Teardown : Cleanup State Files
Teardown --> GHA -- : Done

GHA --> User -- : Benchmark Complete
@enduml
